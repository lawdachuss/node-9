# Required: Supabase configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_API_KEY=your_supabase_anon_key

# ── REQUIRED: Chaturbate auth ────────────────────────────
# Get these from your browser after logging into chaturbate.com.
# CRITICAL: Use Chrome 146+ on Windows to match the TLS fingerprint preset.
#   Chrome:  F12 → Application → Cookies → chaturbate.com → copy all as string
#   Firefox: F12 → Storage → Cookies → chaturbate.com
# If cookies were collected from a different browser version, Cloudflare may
# still challenge the request (cf_clearance is bound to the TLS fingerprint).
COOKIES="sessionid=your_session_id; csrftoken=your_csrftoken"
USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/146.0.0.0 Safari/537.36"

# ── IP REPUTATION ────────────────────────────────────────
# Cloudflare also scores your IP address. Residential/home ISP IPs work best.
# Datacenter/VPS IPs (AWS, DigitalOcean, Hetzner, etc.) often get challenged
# or blocked even with a perfect TLS fingerprint. If running on a VPS:
#   - Route traffic through a residential proxy (SOCKS5)
#   - Or use a VPN back to your home network
#   - Or accept that some channels may be intermittently blocked

# Optional: Upload host API keys
IMGBB_API_KEY=your_imgbb_api_key[,key2,key3]
VOESX_API_KEY=your_voesx_api_key
SEEKSTREAMING_KEY=your_seekstreaming_api_key
SENDCM_API_KEY=your_sendcm_api_key
BYSE_API_KEY=your_byse_api_key

# Optional: GitHub preview fallback
GITHUB_TOKEN=your_github_token
GITHUB_REPO=owner/repo
GITHUB_BRANCH=main
GITHUB_PREVIEW_PATH=previews

# Optional: Proxy for Byparr/Cloudflare bypass
PROXY_URL=http://proxy.example.com:8080
PROXY_USERNAME=
PROXY_PASSWORD=

# Optional: Chaturbate API pacing for large channel lists.
# HLS playlist/segment downloads are not limited by these; only stream discovery
# calls are paced. Raise cautiously when using strong residential/proxy IPs.
CHATURBATE_API_INITIAL_RPS=25
CHATURBATE_API_MIN_RPS=5
CHATURBATE_API_MAX_RPS=100
CHATURBATE_API_BURST=250

# Optional: Instance ID for multi-instance setups
INSTANCE_ID=default

# Optional: recording window before the app stops channels and uploads.
# For 6-hour temporary runners recording many channels, leave upload time.
SESSION_DURATION=4h30m0s
